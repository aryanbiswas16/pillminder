# Database Configuration
# For prototype/demo use, SQLite is used by default (no setup required).
# Optional: set DB_DIALECT=postgres and the variables below to use PostgreSQL.
DB_DIALECT=sqlite
# SQLITE_STORAGE=./data/pillminder.sqlite

# PostgreSQL (optional)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pillminder
DB_USER=postgres
DB_PASSWORD=your_password

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Server Configuration
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
